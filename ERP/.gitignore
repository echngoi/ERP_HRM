# ============================================================
# ERP System — Git Ignore
# ============================================================

# --- Environment ---
.env
*.env.local

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.egg-info/
venv/
.venv/

# --- Django ---
backend/db.sqlite3
backend/staticfiles/
backend/media/*
!backend/media/.gitkeep

# --- Node / Frontend ---
frontend/node_modules/
frontend/dist/
frontend/dist-ssr/
*.local

# --- Docker ---
cloudflared/

# --- OS ---
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# --- IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- Logs ---
*.log
npm-debug.log*

# --- Backup ---
backups/
*.sql
